// DAppConnector handles ALL wallet types:
//   - HashPack    (Hedera native, WalletConnect)
//   - Blade       (Hedera native, WalletConnect)
//   - Kabila      (Hedera native, WalletConnect)
//   - MetaMask    (EVM via Hedera JSON-RPC relay)
//
// Only one instance is created for the whole app (singleton).

import SignClient from "@walletconnect/sign-client";
import { WalletConnectModal } from "@walletconnect/modal";

const PROJECT_ID = import.meta.env.VITE_WALLETCONNECT_PROJECT_ID ?? "";

// Hedera TESTNET chain ID in CAIP-2 format
const APP_METADATA = {
    name: "OrderbookDex",
    description:
        "OrderbookDex — Fair Orderbook DEX on Hedera — anti-front-running via HCS",
    url: typeof window !== "undefined" ? window.location.origin : "",
    icons: ["https://avatars.githubusercontent.com/u/31002956"]
};

// Singletons
let _client: SignClient | null = null;
let _modal: WalletConnectModal | null = null;

// ── Get or create SignClient ──────────────────────────────
export async function getSignClient(): Promise<Siglient> {
    if (!_client) {
        _client = await SignClient.init({
            projectId: PROJECT_ID,
            metaData: APP_METADATA
        });
    }
    return _client;
}

// ── Get or create Modal ──────────────────────────────
export function getModal(): WalletConnectModal {
    if (!_modal) {
        _modal = new WalletConnectModal({
            projectId: PROJECT_ID,
            chains: [HEDERA_TESTNET],
            themeMode: "dark",
            themeVariables: {
                "--wcm-background-color": "#0D0F18",
                "--wcm-accent-color": "#00BCD4"
            }
        });
    }
    return _modal;
}

// ── Connect — returns accountId ────────
export async function connectWalletConnect(): Promise<string> {
    const client = await getSignClient();
    const modal = getModal();
    // Create new pairing session
    const { uri, approval } = await client.connect({
        requiredNameSpace: {
            hedera: {
                methods: [
                    "hedera_signAndExecuteTransaction",
                    "hedera_executeTransaction"
                ],
                chains: [HEDERA_TESTNET],
                events: [accountsChanged, chainChanged]
            }
        }
    });
    // Open QR modal if a URi was returned
    if (uri) {
        await modal.openModal({ uri });
    }

    // Wait for user to approve im their WalletConnectModal
    const session = await approval();
    modal.closeModal();

    // Extract account ID from session
    // Format: "hedera:testnet:0.0.1234567"
    const accounts = session.namespaces.hedera?.accounts ?? [];
    if (accounts.length === 0) throw new Error("No accounts in this session");

    const accountId = accounts[0].split(":")[2];
    return accountId;
}

// ── Disconnect all sessions ───────────────────────────────
export async function disconnectAll(): Promise<void> {
    try {
        const client = getSignClient();
        const sessions = client.session.getAll();
        await Promise.all(
            sessions.map(s =>
                client.disconnect({
                    topic: s.topic,
                    reason: { code: 6000, message: "User disconnected" }
                })
            )
        );
    } catch {}
}

// ── Restore existing session if one exist ───────────────────────────────
export async function getExistingAccountId(): Promise<string | null> {
    try {
        const client = await getSignClient();
        const sessions = client.session.getAll();
        if (sessions.length === 0) return null;

        const accounts = sessions[0].namespaces.hedera?.accounts ?? [];
        if (accounts.length === 0) return null;

        return accounts[0].split(":")[2];
    } catch {
        return null;
    }
}
